# Task Queue Dashboard Environment Variables

# SQLite database file path
DATABASE_PATH=./data/task-queue.db

# Server configuration
PORT=3518
HOST=0.0.0.0

# Antfarm configuration
ANTFARM_BIN_PATH=/usr/bin/node ~/.local/bin/antfarm

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info
